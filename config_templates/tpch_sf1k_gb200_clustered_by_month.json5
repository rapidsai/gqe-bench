// This is a general config for running SF1K on GB200 using the clustered by month data set. Generated Feb 2026
// Most configurations are valid regardless of dataset
// Depending on clustering method and scale factor, alter dataset, zone_map_partition_size
{
  "dataset": "/tpch-sf1000-clustered-by-month", // these paths have to exist in your container, or change it!
  "plan": "/plan",
  "solution": "/solution_sf1k/%d.parquet",
  "output": "/output/pbr_output.db3",
  "time_breakdown": false,

  "storage_kind": ["numa_pinned_memory"],
  "identifier_type": ["int64"],
  "compression_format": ["lz4"], // uses decomp engine on GB200
  "use_cpu_compression": [true], //slows down comp speed but great IO
  "compression_level": [12],
  "secondary_compression_format": ["cascaded"],
  "read_use_overlap_mtx": [false], // Change to false when running with compression enabled
  "join_use_mark_join": [false],
  "filter_use_like_shift_and": [false],
  "aggregation_use_perfect_hash": [true], // Set to true when using clustered dataset
  "read_use_filter_pruning": [true],
  "zone_map_partition_size": [10000000], // Set based on dataset clustering method and scale factor
  "row_groups": [14, 28],
  "partitions": [4, 8, 16, 32],
  "workers": [2, 4, 8],
  "sandboxing": true,
  "data_timeout": 1200,
  "query_timeout": 30,
  "query_source": "both",
  "load_all_data": false,

  "query_overrides": [
    {
      "queries": [
        "1",
        "2_fused_filter",
        "3_fused_filter",
        "4",
        "6",
        "7_fused_filter",
        "8",
        "10_fused_filter",
        "10_opt",
        "13",
        "13_opt",
        "13_fused",
        "14",
        "16",
        "16_opt",
        "17",
        "18_opt",
        "19",
        "20_fused_filter",
        "21_fused_filter",
        "21_opt",
        "22",
        "22_opt"
      ],
      "join_use_perfect_hash": [false, true],
      "join_use_hash_map_cache": [false, true]
    },
    {
      "queries": [
        "4",
        "16",
        "20",
        "21",
        "22"
      ],
      "join_use_mark_join": [false, true]
    },
    {
      "queries": [
        "2",
        "9",
        "13",
        "14",
        "16",
        "20"
      ],
      "filter_use_like_shift_and": [false, true]
    },
    {
      "queries": [
        "1",
        "2",
        "3",
        "6",
        "11",
        "15",
        "17",
        "18",
        "19",
        "20"
      ],
      "aggregation_use_perfect_hash": [false, true]
    }
  ]
}
